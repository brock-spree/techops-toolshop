{
  "domain": "tech-ops",
  "spreelets": [
    {
      "id": "prism",
      "manifestUrl": "http://localhost:3001/.well-known/spreelet.json",
      "fallback": {
        "id": "prism",
        "name": "Prism",
        "description": "Generate stakeholder comms, manage roadmaps, explore KPIs, and improve data quality",
        "icon": "compass",
        "version": "1.1.0",
        "url": "http://localhost:3001",
        "domain": "tech-ops",
        "tags": ["stakeholder-comms", "roadmap", "kpis", "data-quality", "teams"],
        "surfaces": {
          "card": {
            "summaryEndpoint": "http://localhost:3001/api/summary",
            "refreshInterval": 300
          },
          "spark": {
            "component": "http://localhost:3001/spreelet-spark.js",
            "preferredSurface": "panel",
            "maxWidth": 520,
            "maxHeight": 720
          },
          "full": {
            "url": "http://localhost:3001",
            "deepLinkParams": ["team", "view", "horizon"]
          }
        },
        "entities": {
          "owns": [
            {
              "domain": "teams",
              "types": ["team", "person"],
              "description": "Canonical team and person entities with alias resolution",
              "schema": "entities/teams.schema.json"
            },
            {
              "domain": "roadmap-items",
              "types": ["roadmap-item", "epic"],
              "description": "Roadmap items with horizon, impact, effort, and DQ scores",
              "schema": "entities/roadmap-items.schema.json"
            },
            {
              "domain": "snapshots",
              "types": ["snapshot"],
              "description": "LTR snapshots with narrative summaries and KPI aggregates"
            }
          ],
          "uses": [
            {
              "domain": "issues",
              "types": ["issue", "epic", "story"],
              "source": "jira:PRDCT,SPREE,SPRT,STPSF"
            },
            {
              "domain": "kpis",
              "types": ["kpi"],
              "source": "trino:mrt_jira__operations_metrics_report"
            }
          ]
        },
        "capabilities": ["entity-resolution", "export", "ai-generation"]
      }
    },
    {
      "id": "sightline",
      "manifestUrl": "http://localhost:3002/.well-known/spreelet.json",
      "fallback": {
        "id": "sightline",
        "name": "Sightline",
        "description": "Search for any Jira issue using natural language with AI-powered entity resolution and status detail",
        "icon": "search",
        "version": "1.1.0",
        "url": "http://localhost:3002",
        "domain": "tech-ops",
        "tags": ["search", "jira", "issues", "status", "natural-language"],
        "surfaces": {
          "spark": {
            "component": "http://localhost:3002/spreelet-spark.js",
            "preferredSurface": "modal",
            "maxWidth": 480,
            "maxHeight": 640
          },
          "full": {
            "url": "http://localhost:3002",
            "deepLinkParams": ["query", "issueKey", "teamHint"]
          }
        },
        "entities": {
          "owns": [
            {
              "domain": "issues",
              "types": ["issue", "epic", "story"],
              "description": "Jira issue search, status tracking, and risk assessment",
              "schema": "entities/issues.schema.json"
            }
          ],
          "uses": [
            {
              "domain": "teams",
              "types": ["team"],
              "source": "prism"
            },
            {
              "domain": "people",
              "types": ["person"],
              "source": "prism"
            }
          ]
        },
        "capabilities": ["search", "entity-resolution"]
      }
    },
    {
      "id": "array",
      "manifestUrl": "http://localhost:3003/.well-known/spreelet.json",
      "fallback": {
        "id": "array",
        "name": "Array",
        "description": "Sprint-over-sprint KPI matrix with work breakdown, estimates, and AI-generated LTR reports",
        "icon": "bar-chart-3",
        "version": "1.1.0",
        "url": "http://localhost:3003",
        "domain": "tech-ops",
        "tags": ["kpis", "sprints", "metrics", "teams", "ltr"],
        "surfaces": {
          "card": {
            "summaryEndpoint": "http://localhost:3003/api/summary",
            "refreshInterval": 600
          },
          "spark": {
            "component": "http://localhost:3003/spreelet-spark.js",
            "preferredSurface": "panel",
            "maxWidth": 520,
            "maxHeight": 720
          },
          "full": {
            "url": "http://localhost:3003",
            "deepLinkParams": ["team", "sprint"]
          }
        },
        "entities": {
          "owns": [
            {
              "domain": "kpis",
              "types": ["kpi", "sprint-metric"],
              "description": "Sprint KPI metrics by team — EBITDA, story points, work breakdown, completion rates",
              "schema": "entities/kpis.schema.json"
            },
            {
              "domain": "estimates",
              "types": ["estimate"],
              "description": "Team-entered sprint estimates for goal tracking"
            }
          ],
          "uses": [
            {
              "domain": "teams",
              "types": ["team"],
              "source": "prism"
            },
            {
              "domain": "issues",
              "types": ["issue"],
              "source": "trino:mrt_jira__operations_metrics_report"
            }
          ]
        },
        "capabilities": ["export", "ai-generation"]
      }
    }
  ]
}
